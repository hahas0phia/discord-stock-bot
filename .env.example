# Discord Bot Configuration
DISCORD_TOKEN=your_discord_bot_token_here

# Database Configuration
# For Oracle Cloud: Use PostgreSQL connection string
# DATABASE_URL=postgresql://user:password@oracle-db.example.com:5432/discord_bot
# For local development: Use SQLite (automatic fallback)
DATABASE_URL=sqlite:////tmp/alerts.db

# Server Port
PORT=8080

# Optional: IBKR Configuration (if using IBKR integration)
# IBKR_FLEX_TOKEN=your_flex_token
# IBKR_QUERY_ID=your_query_id
